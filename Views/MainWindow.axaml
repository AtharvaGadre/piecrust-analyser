<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PiecrustAnalyser.CSharp.ViewModels"
        xmlns:models="using:PiecrustAnalyser.CSharp.Models"
        xmlns:controls="using:PiecrustAnalyser.CSharp.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PiecrustAnalyser.CSharp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Pie Crust Analyser"
        Width="1480"
        Height="940"
        MinWidth="1200"
        MinHeight="760"
        Background="#100c08"
        Foreground="#ead9bf">
    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2a1a08"/>
            <Setter Property="Foreground" Value="#d4a056"/>
            <Setter Property="BorderBrush" Value="#6b4226"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#372212"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1a1008"/>
            <Setter Property="Foreground" Value="#d4a056"/>
            <Setter Property="BorderBrush" Value="#3a2a16"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#1a1008"/>
            <Setter Property="Foreground" Value="#d4a056"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="#120d08"/>
            <Setter Property="Foreground" Value="#ead9bf"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Background" Value="#1b130b"/>
            <Setter Property="Foreground" Value="#d4a056"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="#2a1a08"/>
            <Setter Property="Foreground" Value="#f0d39a"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="10">
        <Border Grid.Row="0" Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel Spacing="8">
                <WrapPanel>
                    <Button Content="Load Files / Browse" Click="OnLoadFilesClick" Margin="0,0,8,0"/>
                    <Button Content="Auto Organize Conditions + Sequence" Click="OnAutoNumberFilesClick" Margin="0,0,8,0"/>
                    <Button Content="Remove Selected Image" Click="OnRemoveSelectedClick" Margin="0,0,8,0"/>
                    <Button Content="Mark Profile Line" Click="OnMarkProfileLineClick" Margin="0,0,8,0"/>
                    <Button Content="Clear Profile Line" Click="OnClearProfileLineClick" Margin="0,0,8,0"/>
                    <Button Content="Start Centre Line" Click="OnStartGuideClick" Margin="0,0,8,0"/>
                    <Button Content="Finish Centre Line" Click="OnFinishGuideClick" Margin="0,0,8,0"/>
                    <Button Content="Undo Last Point" Click="OnUndoGuidePointClick" Margin="0,0,8,0"/>
                    <Button Content="Clear Centre Line" Click="OnClearGuideClick" Margin="0,0,8,0"/>
                    <Button Content="Run Guided Extraction" Click="OnRunGuidedExtractionClick" Margin="0,0,8,0"/>
                    <Button Content="Export Guided CSV" Click="OnExportCsvClick"/>
                </WrapPanel>

                <Grid ColumnDefinitions="300,190,170,170,360,*" ColumnSpacing="10">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Files" FontWeight="SemiBold" Foreground="#d8b07a"/>
                        <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile, Mode=TwoWay}" Height="110" Background="#120d08" BorderBrush="#352615">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}"/>
                                        <TextBlock Text="{Binding SequenceOrder, StringFormat=\#{0}}" Foreground="#f0c978"/>
                                        <TextBlock Text="{Binding Stage}" Foreground="#a7c47d"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Corridor Width (nm)" Foreground="#d8b07a"/>
                        <TextBox Text="{Binding SelectedFile.GuideCorridorWidthNm, Mode=TwoWay}" LostFocus="OnSelectionFieldChanged"/>
                        <TextBlock Text="Dose (ug/mL)" Foreground="#d8b07a" Margin="0,8,0,0"/>
                        <TextBox Text="{Binding SelectedFile.AntibioticDoseUgPerMl, Mode=TwoWay}" LostFocus="OnSelectionFieldChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Condition" Foreground="#d8b07a"/>
                        <ComboBox ItemsSource="{Binding ConditionOptions}" SelectedItem="{Binding SelectedFile.ConditionType, Mode=TwoWay}" SelectionChanged="OnSelectionFieldChanged"/>
                        <TextBlock Text="Stage" Foreground="#d8b07a" Margin="0,8,0,0"/>
                        <ComboBox ItemsSource="{Binding StageOptions}" SelectedItem="{Binding SelectedFile.Stage, Mode=TwoWay}" SelectionChanged="OnSelectionFieldChanged"/>
                        <TextBlock Text="{Binding SelectedStageHintText}" TextWrapping="Wrap" Foreground="#bca37d" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="Sequencing" Foreground="#d8b07a"/>
                        <ComboBox ItemsSource="{Binding SequencingModeOptions}" SelectedItem="{Binding SelectedSequencingMode, Mode=TwoWay}"/>
                        <TextBlock Text="Sequence #" Foreground="#d8b07a"/>
                        <TextBox Text="{Binding SelectedFile.SequenceOrder, Mode=TwoWay}" LostFocus="OnSelectionFieldChanged" IsEnabled="{Binding IsManualSequencing}"/>
                        <TextBlock Text="Format" Foreground="#d8b07a"/>
                        <TextBlock Text="{Binding SelectedFile.Format}"/>
                        <TextBlock Text="Scan Size (nm)" Foreground="#d8b07a" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding SelectedFile.ScanSizeNm, StringFormat={}{0:F2}}"/>
                    </StackPanel>

                    <Border Grid.Column="4" Background="#120d08" BorderBrush="#352615" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Status" FontWeight="SemiBold" Foreground="#d8b07a"/>
                            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding AutomaticOrganisationSummaryText}" TextWrapping="Wrap" Foreground="#bca37d" FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="5" Background="#120d08" BorderBrush="#352615" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Session Log" FontWeight="SemiBold" Foreground="#d8b07a"/>
                            <TextBlock Text="{Binding SessionLogCaption}" Foreground="#8a7a5a" FontSize="11"/>
                            <ListBox ItemsSource="{Binding ActivityLogs}" Height="86" BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ActivityLogEntry">
                                        <StackPanel Spacing="1" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding TimestampText}" Foreground="#8a7a5a" FontSize="11"/>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{Binding AccentHex}" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Image + Profile">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" Spacing="8" MinWidth="1040">
                        <Grid ColumnDefinitions="2.45*,0.95*" ColumnSpacing="10">
                            <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="8">
                                <controls:HeightMapCanvasControl x:Name="HeightMapCanvas"
                                                                 Bitmap="{Binding SelectedFile.PreviewBitmap}"
                                                                 ProfileLine="{Binding SelectedFile.ProfileLine}"
                                                                 GuidePoints="{Binding SelectedFile.GuidePoints}"
                                                                 GuideFinished="{Binding SelectedFile.GuideLineFinished}"
                                                                 CorridorHalfWidthPixels="{Binding CurrentCorridorHalfWidthPixels}"/>
                            </Border>

                            <Border Grid.Column="1" Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="8">
                                <ScrollViewer>
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Current File" FontSize="15" FontWeight="Bold" Foreground="#d8b07a"/>
                                        <TextBlock Text="{Binding SelectedFileNameText}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedChannelDisplayText}"/>
                                        <TextBlock Text="{Binding SelectedDisplayMinText}"/>
                                        <TextBlock Text="{Binding SelectedDisplayMaxText}"/>
                                        <TextBlock Text="{Binding SelectedDisplayReferenceText}"/>
                                        <TextBlock Text="{Binding SelectedEstimatedNoiseText}"/>
                                        <TextBlock Text="{Binding SelectedMeanHeightText}"/>
                                        <TextBlock Text="{Binding SelectedMeanWidthText}"/>
                                        <TextBlock Text="{Binding SelectedHeightWidthRatioText}"/>
                                        <TextBlock Text="{Binding SelectedEdgeAngleText}"/>
                                        <TextBlock Text="{Binding SelectedAreaProxyText}"/>
                                        <TextBlock Text="{Binding SelectedContinuityText}"/>
                                        <TextBlock Text="{Binding SelectedPeakSeparationText}"/>
                                        <Separator/>
                                        <TextBlock Text="Growth Quantification" FontWeight="Bold" Foreground="#d8b07a"/>
                                        <TextBlock Text="{Binding CurrentAdditionRateText}"/>
                                        <TextBlock Text="{Binding CurrentRemovalRateText}"/>
                                        <TextBlock Text="{Binding CurrentCompromiseText}"/>
                                        <Separator/>
                                        <TextBlock Text="Colour Mapping" FontSize="15" FontWeight="Bold" Foreground="#d8b07a"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ComboBox ItemsSource="{Binding DisplayModeOptions}" SelectedItem="{Binding SelectedDisplayRangeMode, Mode=TwoWay}" Width="110"/>
                                            <Button Content="Set Auto As Fixed" Click="OnSetAutoDisplayFixedClick"/>
                                        </StackPanel>
                                        <Border Background="#16100a" BorderBrush="#2a1a0a" BorderThickness="1" CornerRadius="5" Padding="6">
                                            <controls:DisplayRangeHistogramControl Histogram="{Binding SelectedDisplayHistogram}"
                                                                                   WindowStartPercent="{Binding SelectedDisplayWindowStartPercent}"
                                                                                   WindowEndPercent="{Binding SelectedDisplayWindowEndPercent}"
                                                                                   Height="78"/>
                                        </Border>
                                        <Grid ColumnDefinitions="42,*,84,28" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Start" VerticalAlignment="Center"/>
                                            <Slider Grid.Row="0" Grid.Column="1"
                                                    Minimum="{Binding SelectedDisplayBoundsMin}"
                                                    Maximum="{Binding SelectedDisplayBoundsMax}"
                                                    TickFrequency="{Binding SelectedDisplaySliderStep}"
                                                    Value="{Binding SelectedDisplayRangeMin, Mode=TwoWay}"/>
                                            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding SelectedDisplayRangeMin, Mode=TwoWay}"/>
                                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SelectedFile.Unit}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="End" VerticalAlignment="Center"/>
                                            <Slider Grid.Row="1" Grid.Column="1"
                                                    Minimum="{Binding SelectedDisplayBoundsMin}"
                                                    Maximum="{Binding SelectedDisplayBoundsMax}"
                                                    TickFrequency="{Binding SelectedDisplaySliderStep}"
                                                    Value="{Binding SelectedDisplayRangeMax, Mode=TwoWay}"/>
                                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedDisplayRangeMax, Mode=TwoWay}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedFile.Unit}" VerticalAlignment="Center"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="Full range" Foreground="#8a7a5a" FontSize="11"/>
                                            <TextBlock Text="{Binding SelectedDisplayBoundsMin, StringFormat={}{0:F2}}" Foreground="#8a7a5a" FontSize="11"/>
                                            <TextBlock Text="to" Foreground="#8a7a5a" FontSize="11"/>
                                            <TextBlock Text="{Binding SelectedDisplayBoundsMax, StringFormat={}{0:F2}}" Foreground="#8a7a5a" FontSize="11"/>
                                            <TextBlock Text="{Binding SelectedFile.Unit}" Foreground="#8a7a5a" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                        <TextBlock Text="Displayed line profiles now show the raw sampled height from the original data so tall uncorrected peaks remain visible instead of being baseline-limited." TextWrapping="Wrap" Foreground="#bca37d"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Line Profile" FontWeight="Bold" Foreground="#d8b07a" VerticalAlignment="Center"/>
                            <Button Content="Download Line Profile CSV" Click="OnExportLineProfileCsvClick"/>
                        </StackPanel>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" MinWidth="980" Height="340">
                            <controls:LinePlotControl Series="{Binding CurrentProfileSeries}"
                                                      Title="Line Profile"
                                                      XAxisLabel="{Binding CurrentProfileXAxisLabel}"
                                                      YAxisLabel="{Binding CurrentProfileYAxisLabel}"
                                                      LightTheme="True"/>
                        </Border>
                        <TextBlock Text="{Binding AngleConstructionText}" Foreground="#d66f45" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Box Plots">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" Spacing="8" MinWidth="1040">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Guided Box Plots" FontWeight="Bold" Foreground="#d8b07a" VerticalAlignment="Center"/>
                            <TextBlock Text="Analysis Cohort" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AnalysisCohortOptions}" SelectedItem="{Binding SelectedAnalysisCohort, Mode=TwoWay}" Width="140"/>
                            <Button Content="Download Box Plot CSV" Click="OnExportBoxPlotsCsvClick"/>
                        </StackPanel>
                        <TextBlock Text="Each box is built from line profiles sampled perpendicular to the guided centre line. Heights now use the raw peak values from those sampled profiles, while widths still use tramline peak separation. The selected cohort controls which condition bucket is included in these plots and summaries." TextWrapping="Wrap" Foreground="#bca37d"/>
                        <TextBlock Text="Per-stage summary from image-level replicates" FontWeight="Bold" Foreground="#d8b07a"/>
                        <ItemsControl ItemsSource="{Binding StageSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:StageSummaryRow">
                                    <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                        <Grid ColumnDefinitions="*,*,*,*,*,*,*,*" ColumnSpacing="12">
                                            <TextBlock Text="{Binding Stage}" FontWeight="SemiBold" Foreground="#f0c978"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ImageCount, StringFormat=Images {0}}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding HeightMeanNm, StringFormat=Height {0:F2} nm}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding HeightStdNm, StringFormat=Height SD {0:F2} nm}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding WidthMeanNm, StringFormat=Width {0:F2} nm}"/>
                                            <TextBlock Grid.Column="5" Text="{Binding WidthStdNm, StringFormat=Width SD {0:F2} nm}"/>
                                            <TextBlock Grid.Column="6" Text="{Binding HeightWidthRatioMean, StringFormat=H/W {0:F4}}"/>
                                            <TextBlock Grid.Column="7" Text="{Binding HeightWidthRatioStd, StringFormat=H/W SD {0:F4}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Height Box Plots by Auto Sequence (raw nm)" FontWeight="Bold" Foreground="#d8b07a"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" MinWidth="980" Height="280">
                            <controls:BoxPlotControl Datasets="{Binding HeightBoxPlots}" XAxisTitle="Auto sequence by increasing raw height"/>
                        </Border>
                        <TextBlock Text="Width Box Plots by Auto Sequence (nm)" FontWeight="Bold" Foreground="#d8b07a"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" MinWidth="980" Height="280">
                            <controls:BoxPlotControl Datasets="{Binding WidthBoxPlots}" XAxisTitle="Auto sequence by increasing raw height"/>
                        </Border>
                        <TextBlock Text="Height/Width Ratio by Auto Sequence" FontWeight="Bold" Foreground="#d8b07a"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" MinWidth="980" Height="280">
                            <controls:BoxPlotControl Datasets="{Binding HeightWidthRatioBoxPlots}" XAxisTitle="Auto sequence by increasing raw height"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Growth Angle">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" Spacing="10" MinWidth="1040">
                        <TextBlock Text="Growth-angle model: the app finds the fitted/smoothed profile peak, finds the nearest near-baseline point on the selected outer flank, draws the construction triangle, and reports the outer angle θ = 180° - atan2(peak-base height, lateral distance). It only reaches 90° if the outer flank becomes close to vertical; otherwise it stays above 90° because the measured geometry itself is shallower." TextWrapping="Wrap" Foreground="#bca37d"/>
                        <TextBlock Text="{Binding GeometryGrowthSummaryText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                        <Grid ColumnDefinitions="1.28*,1*" ColumnSpacing="14">
                            <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Extraction" FontWeight="Bold" Foreground="#d8b07a"/>
                                    <WrapPanel ItemWidth="200" Orientation="Horizontal">
                                        <CheckBox Content="Enable growth-angle model" IsChecked="{Binding EnableFigure5AngleModel, Mode=TwoWay}" Margin="0,0,12,8"/>
                                        <CheckBox Content="Show dotted construction" IsChecked="{Binding ShowFigure5ConstructionLine, Mode=TwoWay}" Margin="0,0,12,8"/>
                                        <CheckBox Content="Show scatter" IsChecked="{Binding ShowAngleHeightScatter, Mode=TwoWay}" Margin="0,0,12,8"/>
                                        <CheckBox Content="Baseline-relative angles" IsChecked="{Binding BaselineRelativeAngle, Mode=TwoWay}" Margin="0,0,12,8"/>
                                    </WrapPanel>
                                    <Grid ColumnDefinitions="Auto,130,Auto,125,Auto,125,Auto,125" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Flank" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Figure5FlankOptions}" SelectedItem="{Binding SelectedFigure5FlankMode, Mode=TwoWay}" Width="125" MinHeight="36"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Near-base threshold" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding PeakBaseThresholdOptions}" SelectedItem="{Binding SelectedPeakBaseThreshold, Mode=TwoWay}" Width="120" MinHeight="36"/>
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Max base distance nm" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding MaxBaseDistanceNm, Mode=TwoWay}" Width="120" MinHeight="36" HorizontalContentAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="6" Text="Smoothing window" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="7" Text="{Binding AngleSmoothingWindow, Mode=TwoWay}" Width="120" MinHeight="36" HorizontalContentAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Displayed fit" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AngleHeightFitOptions}" SelectedItem="{Binding SelectedAngleHeightFitType, Mode=TwoWay}" Width="125" MinHeight="36"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="6" Text="The actual growth/equation anchor is fixed to quadratic (polynomial 2) for consistency. This dropdown only changes the comparison overlay in the angle plot." TextWrapping="Wrap" Foreground="#bca37d" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Scatter profiles / image" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AngleScatterProfilesPerImage, Mode=TwoWay}" Width="120" MinHeight="36" HorizontalContentAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="6" Text="Uses equidistant valid guided profiles per image in the angle scatter, and the same count is used the next time Equation Discovery is run. Minimum 10, maximum 100." TextWrapping="Wrap" Foreground="#bca37d" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="{Binding AngleConstructionText}" Foreground="#f0c978" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Angle Coupling" FontWeight="Bold" Foreground="#d8b07a"/>
                                    <WrapPanel ItemWidth="210" Orientation="Horizontal">
                                        <Button Content="Download angle vs height CSV" Click="OnExportAngleVsHeightCsvClick" Margin="0,0,12,8"/>
                                    </WrapPanel>
                                    <TextBlock Text="The angle tab now supports extraction, scatter plotting, CSV export, and a quadratic angle-height comparison anchor within the observed sequence only. Future tau prediction has been removed." TextWrapping="Wrap" Foreground="#bca37d"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Background="#120c07" BorderBrush="#4b361f" BorderThickness="1" CornerRadius="6" Height="340">
                            <controls:LinePlotControl Series="{Binding ControlAngleHeightScatterSeries}"
                                                      Title="Control Outer Growth Angle vs Piecrust Height"
                                                      XAxisLabel="Piecrust height [nm]"
                                                      YAxisLabel="outer θ [deg]"
                                                      FixedYMin="90"
                                                      FixedYMax="180"
                                                      LightTheme="True"/>
                        </Border>
                        <TextBlock Text="{Binding ControlAngleHeightScatterLegendText}" TextWrapping="Wrap" Foreground="#f0c978"/>
                        <Border Background="#120c07" BorderBrush="#4b361f" BorderThickness="1" CornerRadius="6" Height="340">
                            <controls:LinePlotControl Series="{Binding TreatedAngleHeightScatterSeries}"
                                                      Title="Treated Outer Growth Angle vs Piecrust Height"
                                                      XAxisLabel="Piecrust height [nm]"
                                                      YAxisLabel="outer θ [deg]"
                                                      FixedYMin="90"
                                                      FixedYMax="180"
                                                      LightTheme="True"/>
                        </Border>
                        <TextBlock Text="{Binding TreatedAngleHeightScatterLegendText}" TextWrapping="Wrap" Foreground="#f0c978"/>
                        <TextBlock Text="Each point is one guided perpendicular profile from the relevant condition. Larger dots are per-image means, and the dashed line follows the mean trend within that same condition bucket." TextWrapping="Wrap" Foreground="#d8c29a"/>
                        <TextBlock Text="{Binding ConditionComparisonSummaryText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Growth Model">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" Spacing="8" MinWidth="1040">
                        <TextBlock Text="Number imported TIFF/SPM references in sequence, choose a start and end file, and the model will use all numbered references in between to fit a centered quadratic surface evolution whose displayed cross-section is constrained by a bimodal Gaussian growth fit over pseudo-time. You can now choose whether the tramline separation stays fixed, the peak widths stay fixed, only amplitudes grow, or the current fully free bimodal model is used." TextWrapping="Wrap" Foreground="#bca37d"/>
                        <TextBlock Text="{Binding SupervisedModelStatusText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Analysis Cohort" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AnalysisCohortOptions}" SelectedItem="{Binding SelectedAnalysisCohort, Mode=TwoWay}" Width="140"/>
                            <TextBlock Text="Start Reference" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AnalysisCohortFiles}" SelectedItem="{Binding SimulationStartFile, Mode=TwoWay}" Width="220">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:PiecrustFileState">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding SequenceOrder, StringFormat=\#{0}}" Foreground="#f0c978"/>
                                            <TextBlock Text="{Binding Stage}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="End Reference" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AnalysisCohortFiles}" SelectedItem="{Binding SimulationEndFile, Mode=TwoWay}" Width="220">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:PiecrustFileState">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding SequenceOrder, StringFormat=\#{0}}" Foreground="#f0c978"/>
                                            <TextBlock Text="{Binding Stage}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Bimodal Mode" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding GrowthModelModeOptions}" SelectedItem="{Binding SelectedGrowthModelMode, Mode=TwoWay}" Width="190"/>
                            <Button Content="Run Polynomial Evolution" Click="OnRunPolynomialEvolutionClick"/>
                            <Button Content="Play / Pause Simulation" Click="OnToggleSimulationClick"/>
                            <Button Content="Reset Simulation" Click="OnResetSimulationClick"/>
                            <Button Content="Download Growth Model CSV" Click="OnExportGrowthModelCsvClick"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Simulation Progress" VerticalAlignment="Center"/>
                            <Slider Minimum="0" Maximum="{Binding SimulationProgressMaximum}" Value="{Binding SimulationProgress, Mode=TwoWay}" Width="260"/>
                            <TextBlock Text="{Binding SimulationProgress, StringFormat={}t/tau {0:F2}}" VerticalAlignment="Center"/>
                            <CheckBox Content="Enable post-tau continuation" IsChecked="{Binding EnableFuturePrediction, Mode=TwoWay}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                            <TextBlock Text="Post-tau horizon (+tau)" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding PredictionHorizonTau, Mode=TwoWay}" Width="90" MinHeight="32" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Growth-angle extraction and angle-vs-height plotting are in the dedicated Growth Angle tab. If post-tau continuation is enabled here, the model extends from the last fitted bimodal frame and preserves that same two-peak morphology while continuing to grow." TextWrapping="Wrap" Foreground="#d8c29a"/>
                        <TextBlock Text="{Binding SimulationStatusText}" TextWrapping="Wrap" Foreground="#bca37d"/>
                        <TextBlock Text="{Binding SimulationReferenceSummaryText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                        <TextBlock Text="{Binding SimulationSurfaceMetaText}" TextWrapping="Wrap" Foreground="#bca37d"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" MinWidth="980" Height="380">
                            <controls:LinePlotControl Series="{Binding SimulationSeries}"
                                                      Title="Polynomial Surface Evolution Cross-section"
                                                      XAxisLabel="{Binding SimulationXAxisLabel}"
                                                      YAxisLabel="{Binding SimulationYAxisLabel}"
                                                      FixedXMin="{Binding SimulationPlotFixedXMin}"
                                                      FixedXMax="{Binding SimulationPlotFixedXMax}"
                                                      FixedYMin="{Binding SimulationPlotFixedYMin}"
                                                      FixedYMax="{Binding SimulationPlotFixedYMax}"/>
                        </Border>
                        <TextBlock Text="{Binding SimulationPlotLegendText}" Foreground="#d8c29a"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Equation Discovery">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" Spacing="8" MinWidth="1040">
                        <TextBlock Text="Equation Discovery now starts from the actual guided image profiles, not the Growth Model simulation. Run guided extraction on sequenced images first; the app averages the perpendicular profiles per image, fills gaps over pseudo-time inside the observed interval, and ranks image-derived bimodal equation candidates." TextWrapping="Wrap" Foreground="#bca37d"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Analysis Cohort" VerticalAlignment="Center" Foreground="#d8c29a"/>
                            <ComboBox ItemsSource="{Binding AnalysisCohortOptions}" SelectedItem="{Binding SelectedAnalysisCohort, Mode=TwoWay}" Width="140"/>
                            <Button Content="Discover Growth Equations" Click="OnDiscoverGrowthEquationsClick"/>
                            <Button Content="Download Equation CSV" Click="OnExportEquationDiscoveryCsvClick"/>
                            <Button Content="Download Equation JSON" Click="OnExportEquationDiscoveryJsonClick"/>
                        </StackPanel>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding EquationDiscoveryStatusText}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding EquationDiscoveryProfileModeText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                                <TextBlock Text="{Binding EquationDiscoveryStageMappingText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                                <TextBlock Text="{Binding EquationDiscoveryMetaText}" TextWrapping="Wrap" Foreground="#bca37d"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="How To Read The Discovered Equations" FontWeight="Bold" Foreground="#d8b07a"/>
                                <TextBlock Text="{Binding EquationDiscoveryTermGuideText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Ordered Summary Used For Pseudo-time Fitting" FontWeight="Bold" Foreground="#d8b07a"/>
                        <ItemsControl ItemsSource="{Binding EquationDiscoveryStageProfiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:EquationDiscoveryStageProfile">
                                    <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">
                                            <TextBlock Text="{Binding Stage}" FontWeight="SemiBold" Foreground="#f0c978"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Tau, StringFormat=Tau {0:F2}}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SampleCount, StringFormat=Profiles {0}}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding MeanHeightNm, StringFormat=Mean height {0:F2} nm}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding MeanWidthNm, StringFormat=Mean width {0:F2} nm}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Candidate Equation Family" FontWeight="Bold" Foreground="#d8b07a"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Active equation for simulation" VerticalAlignment="Center" Foreground="#d8c29a"/>
                            <ComboBox ItemsSource="{Binding EquationFamily}" SelectedItem="{Binding SelectedEquationCandidate, Mode=TwoWay}" Width="520">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:EquationCandidateResult">
                                        <TextBlock Text="{Binding MethodLabel}" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Content="Simulate Selected Equation" Click="OnSimulateSelectedEquationClick"/>
                            <Button Content="Copy Equation" Click="OnCopyEquationClick"/>
                        </StackPanel>
                        <Border Background="#161008" BorderBrush="#4b361f" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Selected Growth-Model Equation Set" FontWeight="Bold" Foreground="#f0c978"/>
                                <TextBlock Text="This is the exact bimodal Gaussian system currently driving the selected discovery candidate, playback, and diagnostics." TextWrapping="Wrap" Foreground="#d8c29a"/>
                                <Border Background="#120c07" BorderBrush="#4b361f" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <TextBlock Text="{Binding SelectedEquationCandidate.EquationPrimaryLine}"
                                               TextWrapping="Wrap"
                                               FontSize="19"
                                               FontWeight="SemiBold"
                                               Foreground="#fff1d6"
                                               TextAlignment="Center"
                                               FontFamily="STIX Two Math, Cambria Math, Times New Roman"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding SelectedEquationCandidate.EquationSecondaryLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding .}"
                                                       TextWrapping="Wrap"
                                                       Margin="8,0,8,0"
                                                       FontSize="15"
                                                       Foreground="#d8c29a"
                                                       TextAlignment="Center"
                                                       FontFamily="STIX Two Math, Cambria Math, Times New Roman"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding SelectedEquationCandidate.MethodLabel, StringFormat=Source: {0}}" Foreground="#c7a779"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#161008" BorderBrush="#4b361f" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="3D Line-Profile Extension" FontWeight="Bold" Foreground="#f0c978"/>
                                <TextBlock Text="Equation Discovery is exposed as z(x,y,t), where the current 2D line profile is extended uniformly along y. Use the playback slider below as t." TextWrapping="Wrap" Foreground="#d8c29a"/>
                                <Border Background="#120c07" BorderBrush="#4b361f" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <TextBlock Text="{Binding SelectedEquationSurfaceOneLinerText}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               Foreground="#f0c978"
                                               FontFamily="Cascadia Code, Menlo, Consolas, monospace"/>
                                </Border>
                                <Border Background="#120c07" BorderBrush="#4b361f" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <TextBlock Text="{Binding SelectedEquationSurfaceText}"
                                               TextWrapping="Wrap"
                                               FontSize="15"
                                               Foreground="#fff1d6"
                                               FontFamily="Cascadia Code, Menlo, Consolas, monospace"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding EquationFamily}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:EquationCandidateResult">
                                    <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
                                                <TextBlock Text="{Binding Rank, StringFormat=Candidate {0}}" FontWeight="SemiBold" Foreground="#f0c978"/>
                                                <StackPanel Grid.Column="1" Spacing="6">
                                                    <TextBlock Text="{Binding MethodLabel}"
                                                               TextWrapping="Wrap"
                                                               FontWeight="SemiBold"
                                                               Foreground="#d8c29a"/>
                                                    <Border Background="#120c07" BorderBrush="#4b361f" BorderThickness="1" CornerRadius="6" Padding="10">
                                                        <TextBlock Text="{Binding EquationPrimaryLine}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#fff1d6"
                                                                   TextAlignment="Center"
                                                                   FontFamily="STIX Two Math, Cambria Math, Times New Roman"/>
                                                    </Border>
                                                    <ItemsControl ItemsSource="{Binding EquationSecondaryLines}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding .}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="10,0,10,0"
                                                                           FontSize="15"
                                                                           Foreground="#d8c29a"
                                                                           TextAlignment="Center"
                                                                           FontFamily="STIX Two Math, Cambria Math, Times New Roman"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="{Binding ActiveTermsText, StringFormat=Terms: {0}}"
                                                               TextWrapping="Wrap"
                                                               Foreground="#c7a779"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Confidence, StringFormat=Model agreement {0:P0}}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Rmse, StringFormat=RMSE {0:F3}}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding StabilityScore, StringFormat=Stability {0:F2}}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Notes}" Foreground="#bca37d" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Observed vs Reconstructed Ordered Profiles" FontWeight="Bold" Foreground="#d8b07a"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" MinWidth="980" Height="360">
                            <controls:LinePlotControl Series="{Binding EquationOverlaySeries}"
                                                      Title="Observed Reference Profiles vs Bimodal ODE Reconstruction"
                                                      XAxisLabel="{Binding EquationDiscoveryXAxisLabel}"
                                                      YAxisLabel="{Binding EquationDiscoveryYAxisLabel}"
                                                      LightTheme="True"
                                                      FixedXMin="{Binding EquationDiscoveryFixedXMin}"
                                                      FixedXMax="{Binding EquationDiscoveryFixedXMax}"/>
                        </Border>
                        <TextBlock Text="{Binding EquationDiscoveryOverlayLegendText}" Foreground="#d8c29a"/>
                        <TextBlock Text="Pseudo-time Reconstruction Progression" FontWeight="Bold" Foreground="#d8b07a"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" MinWidth="980" Height="360">
                            <controls:LinePlotControl Series="{Binding EquationProgressionSeries}"
                                                      Title="Bimodal Tramline Profile Evolution h(z, tau)"
                                                      XAxisLabel="{Binding EquationDiscoveryXAxisLabel}"
                                                      YAxisLabel="{Binding EquationDiscoveryYAxisLabel}"
                                                      LightTheme="True"
                                                      FixedXMin="{Binding EquationDiscoveryFixedXMin}"
                                                      FixedXMax="{Binding EquationDiscoveryFixedXMax}"/>
                        </Border>
                        <TextBlock Text="{Binding EquationDiscoveryProgressionLegendText}" Foreground="#d8c29a"/>
                        <TextBlock Text="Fit Diagnostics" FontWeight="Bold" Foreground="#d8b07a"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding EquationDiagnosticsSummaryText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                                <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" MinWidth="980" Height="320">
                                    <controls:LinePlotControl Series="{Binding EquationDiagnosticsSeries}"
                                                              Title="Observed - Reconstructed Residuals"
                                                              XAxisLabel="{Binding EquationDiscoveryXAxisLabel}"
                                                              YAxisLabel="Residual height [nm]"
                                                              LightTheme="True"
                                                              FixedXMin="{Binding EquationDiscoveryFixedXMin}"
                                                              FixedXMax="{Binding EquationDiscoveryFixedXMax}"/>
                                </Border>
                                <TextBlock Text="{Binding EquationDiscoveryDiagnosticsLegendText}" Foreground="#d8c29a"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Equation Playback" FontWeight="Bold" Foreground="#d8b07a"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="Play / Pause Playback" Click="OnToggleEquationPlaybackClick"/>
                                    <Button Content="Reset Playback" Click="OnResetEquationPlaybackClick"/>
                                </StackPanel>
                                <TextBlock Text="{Binding EquationPlaybackStatusText}" TextWrapping="Wrap" Foreground="#bca37d"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Frame" VerticalAlignment="Center"/>
                                    <Slider Minimum="0"
                                            Maximum="{Binding EquationPlaybackFrameMaximum}"
                                            Value="{Binding EquationPlaybackFramePosition, Mode=TwoWay}"
                                            Width="300"/>
                                    <TextBlock Text="{Binding EquationPlaybackFramePosition, StringFormat={}{0:F0}}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Speed" VerticalAlignment="Center"/>
                                    <Slider Minimum="0.1"
                                            Maximum="3.0"
                                            Value="{Binding EquationSimulationPlayback.PlaybackSpeed, Mode=TwoWay}"
                                            Width="220"/>
                                    <TextBlock Text="{Binding EquationSimulationPlayback.PlaybackSpeed, StringFormat={}{0:F1}x}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <TextBlock Text="{Binding EquationPlaybackTauText}" Foreground="#d8c29a"/>
                                    <TextBlock Text="{Binding EquationPlaybackHeightText}" Foreground="#d8c29a"/>
                                    <TextBlock Text="{Binding EquationPlaybackWidthText}" Foreground="#d8c29a"/>
                                </StackPanel>
                                <TextBlock Text="Solid line = simulated bimodal feature-evolution profile. Dashed line = matching bimodal Gaussian envelope. Fixed axes keep tramline growth visible across frames." TextWrapping="Wrap" Foreground="#bca37d"/>
                                <Border Background="#f4f0e7" BorderBrush="#d8d2c5" BorderThickness="1" CornerRadius="8" Height="280">
                                    <controls:LinePlotControl Series="{Binding EquationPlaybackSeries}"
                                                              Title="Bimodal Feature Playback"
                                                              XAxisLabel="{Binding EquationDiscoveryXAxisLabel}"
                                                              YAxisLabel="{Binding EquationDiscoveryYAxisLabel}"
                                                              LightTheme="True"
                                                              FixedXMin="{Binding EquationPlaybackFixedXMin}"
                                                              FixedXMax="{Binding EquationPlaybackFixedXMax}"
                                                              FixedYMin="{Binding EquationPlaybackFixedYMin}"
                                                              FixedYMax="{Binding EquationPlaybackFixedYMax}"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Equation Terms">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" Spacing="8" MinWidth="980">
                        <TextBlock Text="This tab explains the symbols used in the image-derived equation family shown in Equation Discovery. The symbols below describe the centered bimodal Gaussian system used for playback, candidate ranking, gap filling, and fit diagnostics." TextWrapping="Wrap" Foreground="#bca37d"/>
                        <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Current Equation Guide" FontWeight="Bold" Foreground="#d8b07a"/>
                                <TextBlock Text="{Binding EquationDiscoveryTermGuideText}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding EquationTermExplanations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:EquationTermExplanation">
                                    <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                        <Grid ColumnDefinitions="220,240,*" ColumnSpacing="12">
                                            <TextBlock Text="{Binding Symbol}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#fff1d6"
                                                       FontFamily="Cascadia Mono, Menlo, Monaco, Consolas, Courier New"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Meaning}" FontWeight="SemiBold" Foreground="#f0c978"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Detail}" TextWrapping="Wrap" Foreground="#d8c29a"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Growth Quant">
                <Grid Margin="10" RowDefinitions="Auto,Auto,*" RowSpacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Analysis Cohort" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AnalysisCohortOptions}" SelectedItem="{Binding SelectedAnalysisCohort, Mode=TwoWay}" Width="140"/>
                        <TextBlock Text="{Binding CompromiseMethodText}" TextWrapping="Wrap" Foreground="#bca37d" MaxWidth="760"/>
                        <Button Content="Download Growth Quant CSV" Click="OnExportGrowthQuantCsvClick"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="{Binding OverallCompromiseSummaryText}" TextWrapping="Wrap" Foreground="#f0c978"/>
                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding GrowthRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#161008" BorderBrush="#352615" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="2*,*,*,*,*,*" ColumnSpacing="12">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ConditionType, StringFormat=Condition {0}}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding MeanHeightNm, StringFormat=Height {0:F2} nm}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding MeanWidthNm, StringFormat=Width {0:F2} nm}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding HeightToWidthRatio, StringFormat=H/W {0:F4}}"/>
                                            <TextBlock Grid.Column="5" Text="{Binding MeanEdgeAngleDeg, StringFormat=Angle {0:F1} deg}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
